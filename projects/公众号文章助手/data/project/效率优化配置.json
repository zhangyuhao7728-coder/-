    "7_成本和安全": {
      "name": "成本与安全",
      "status": "active",
      "description": "Docker沙盒+成本控制",
      "settings": {
        "sandbox_mode": "docker",
        "daily_limit": 1000,
        "monthly_budget": 50
      },
      "commands": [
        "openclaw config set sandbox.mode \"docker\"",
        "openclaw sandbox test",
        "openclaw config set ai.dailyLimit 1000",
        "openclaw config set ai.monthlyBudget 50",
        "openclaw stats cost"
      ]
