{
  "name": "网页搜索",
  "description": "使用Perplexity进行网页搜索",
  "security_level": "medium",
  "config": {
    "enabled": false,
    "provider": "perplexity",
    "model": "perplexity/sonar-pro",
    "api_key_env": "PERPLEXITY_API_KEY"
  },
  "security_notes": [
    "需要Perplexity API Key",
    "建议从 https://www.perplexity.ai/ 获取",
    "API Key应存储在 .env 文件中",
    "不要直接写在配置文件中"
  ],
  "setup_steps": [
    "1. 注册 Perplexity 账号",
    "2. 获取 API Key",
    "3. 添加到 .env 文件: PERPLEXITY_API_KEY=your_key",
    "4. 将下方配置添加到 openclaw.json"
  ],
  "config_snippet": {
    "tools": {
      "web": {
        "search": {
          "enabled": true,
          "provider": "perplexity",
          "perplexity": {
            "apiKey": "${PERPLEXITY_API_KEY}",
            "model": "perplexity/sonar-pro"
          }
        }
      }
    }
  }
}
